def build_db(db_path: Path) -> int:
    """Create schema and populate exercises. Returns number of exercises inserted."""
    db_path.parent.mkdir(parents=True, exist_ok=True)
    conn = sqlite3.connect(str(db_path))
    conn.execute("PRAGMA journal_mode=WAL")
    conn.execute("PRAGMA foreign_keys=ON")
    conn.executescript(SCHEMA)

    # Delete existing exercises so this script is idempotent
    conn.execute("DELETE FROM exercises")

    conn.executemany(
        """INSERT INTO exercises
           (name, category, description, intensity, duration_sec,
            muscle_groups, calories_per_min_approx, source_notes)
           VALUES (?,?,?,?,?,?,?,?)""",
        EXERCISES,
    )
    conn.commit()
    count = conn.execute("SELECT COUNT(*) FROM exercises").fetchone()[0]
    conn.close()
    return count


def main():
    if "--help" in sys.argv or "-h" in sys.argv:
        print(__doc__)
        print(f"Database path: {DB_PATH}")
        return
    count = build_db(DB_PATH)
    print(f"Database built: {count} exercises written to {DB_PATH}")


if __name__ == "__main__":
    main()
