#!/usr/bin/env python3
"""Build / rebuild the microbreak SQLite database with research-backed exercises.

Sources:
  - "Exercise Snacking" concept (Sports Medicine and Health Science, 2025)
  - University of Essex: 16 min bodyweight exercises over 8h → muscle + balance in 4 weeks
  - Lancet Public Health (2023): VILPA — 1-2 min vigorous intermittent activity reduces mortality
  - Stair-climbing study: 3×20 s/day for 6 weeks → VO₂max +5 %, peak power +12 %
  - NEAT (non-exercise activity thermogenesis) research

Categories:
  cardio         — heart-rate elevation, calorie burn, fat oxidation
  strength_upper — chest, shoulders, triceps, back
  strength_lower — quads, glutes, hamstrings, calves
  core           — abdominals, obliques, lower back, stability
  mobility       — flexibility, joint health, posture correction
"""

import sqlite3
import sys
from pathlib import Path

DB_PATH = Path.home() / ".local/share/microbreak/microbreak.db"

SCHEMA = """
CREATE TABLE IF NOT EXISTS exercises (
    id          INTEGER PRIMARY KEY AUTOINCREMENT,
    name        TEXT    NOT NULL,
    category    TEXT    NOT NULL CHECK (category IN (
                    'cardio','strength_upper','strength_lower','core','mobility'
                )),
    description TEXT    NOT NULL,
    intensity   INTEGER NOT NULL CHECK (intensity BETWEEN 1 AND 5),
    duration_sec INTEGER NOT NULL,
    muscle_groups TEXT  NOT NULL,   -- comma-separated
    calories_per_min_approx REAL,
    source_notes TEXT
);

CREATE TABLE IF NOT EXISTS sessions (
    id          INTEGER PRIMARY KEY AUTOINCREMENT,
    date        TEXT    NOT NULL,    -- ISO date YYYY-MM-DD
    time        TEXT    NOT NULL,    -- HH:MM
    exercise_id INTEGER NOT NULL,
    status      TEXT    NOT NULL CHECK (status IN ('done','missed','skipped')),
    FOREIGN KEY (exercise_id) REFERENCES exercises(id)
);

CREATE TABLE IF NOT EXISTS feedback (
    id              INTEGER PRIMARY KEY AUTOINCREMENT,
    session_id      INTEGER NOT NULL UNIQUE,
    difficulty_rating INTEGER CHECK (difficulty_rating BETWEEN 1 AND 5),
    effectiveness_rating INTEGER CHECK (effectiveness_rating BETWEEN 1 AND 5),
    notes           TEXT,
    created_at      TEXT NOT NULL DEFAULT (datetime('now','localtime')),
    FOREIGN KEY (session_id) REFERENCES sessions(id)
);

CREATE INDEX IF NOT EXISTS idx_sessions_date ON sessions(date);
CREATE INDEX IF NOT EXISTS idx_sessions_exercise ON sessions(exercise_id);
CREATE INDEX IF NOT EXISTS idx_feedback_session ON feedback(session_id);
"""

